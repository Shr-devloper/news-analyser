# ============================================================================
# AI News Intelligence Agent — Environment Configuration
# Copy this file to `.env` and fill in the secrets.
# ============================================================================

# ---- General ----
PROJECT_NAME="AI News Intelligence Agent"
ENVIRONMENT=development            # development | production
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# ---- Security ----
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days
ALGORITHM=HS256
# Comma-separated list of allowed CORS origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- First superuser (created on startup) ----
FIRST_SUPERUSER_EMAIL=admin@news.ai
FIRST_SUPERUSER_PASSWORD=ChangeMe123!
FIRST_SUPERUSER_NAME=Administrator

# ---- Database ----
POSTGRES_USER=news
POSTGRES_PASSWORD=news
POSTGRES_DB=news
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://news:news@db:5432/news

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- AI / GroqCloud ----
# Leave GROQ_API_KEY empty to use heuristic fallbacks (pipeline still runs).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DEDUP_SIMILARITY_THRESHOLD=0.78

# ---- Email / SMTP ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=AI News Agent <no-reply@news.ai>
SMTP_TLS=true

# ---- Scheduling ----
REPORT_TIMEZONE=Asia/Kolkata
ENABLE_BEAT=true

# ---- Pipeline tuning ----
MAX_ARTICLES_PER_SOURCE=40
TOP_STORIES_PER_SECTION=10
TOP_STORIES_OVERALL=20
FETCH_WINDOW_HOURS=24

# ---- Daily brief (single-recipient PDF email, sent every morning) ----
BRIEF_RECIPIENT_EMAIL=shresth.t.123@gmail.com
BRIEF_RECIPIENT_NAME=Shresth
BRIEF_INTERESTS=Artificial Intelligence,Software Engineering,Programming,DSA,Startups,Career Growth,Productivity,Emerging Technologies

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
